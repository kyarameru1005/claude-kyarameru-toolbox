{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "model": "opus",
  "includeCoAuthoredBy": true,
  "cleanupPeriodDays": 30,
  "permissions": {
    "allow": [
      "Read",
      "Grep",
      "Glob",
      "Bash(git status:*)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(git switch:*)",
      "Bash(git branch:*)",
      "Bash(python3 -m pytest:*)",
      "Bash(python3 scripts/validate-toolbox.py:*)",
      "Bash(python3 scripts/toolbox-manager.py:*)"
    ],
    "deny": [
      "Bash(git push --force:*)",
      "Bash(git push -f:*)",
      "Bash(git reset --hard:*)",
      "Bash(git clean:*)",
      "Bash(git checkout --:*)",
      "Bash(rm -rf:*)"
    ],
    "ask": [
      "Bash(git rebase:*)",
      "Bash(git branch -D:*)",
      "Bash(git branch -d:*)"
    ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "\"$HOME/.claude/hooks/run-pytest.sh\""
          },
          {
            "type": "command",
            "command": "\"$HOME/.claude/hooks/run-validate-toolbox.sh\""
          }
        ]
      }
    ]
  },
  "env": {}
}
